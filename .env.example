# ─── NEXO — Environment Variables ────────────────────────────────────────────
# Copie: cp .env.example .env

# ── IA ────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx
# OpenAI — necessário para geração de fotos com DALL-E (opcional)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── SCRAPING ──────────────────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxx
SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxx

# ── BANCO DE DADOS ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexo:nexo@localhost:5432/nexo
REDIS_URL=redis://localhost:6379

# ── AUTH ──────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE-POR-CHAVE-SEGURA-32-CHARS

# ── EMAIL ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua-app-password-gmail

# ── TELEGRAM (opcional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── CÂMBIO (fallback) ─────────────────────────────────────────────────────────
USD_TO_BRL_FALLBACK=6.10

# ── SERVIDOR ──────────────────────────────────────────────────────────────────
PORT=8000
# Em produção: coloque o domínio do seu frontend aqui
# Ex: ALLOWED_ORIGINS=https://nexo.seudominio.com
# Em desenvolvimento deixe como * para aceitar tudo
ALLOWED_ORIGINS=*
