  telefoneCliente       String
  nomeCliente           String
  produto               String
  cepDestino            String
  enderecoCompleto      String
  valorProduto          Float
  valorFrete            Float
  valorTotal            Float
  transportadora        String
  prazoFrete            Int
  servicoFreteId        String
  formaPagamento        String
  pagamentoId           String?
  pagamentoStatus       String    @default("PENDENTE")
  pagamentoConfirmado   Boolean   @default(false)
  pagamentoConfirmadoEm DateTime?
  cartItemId            String?
  urlEtiqueta           String?
  codigoRastreamento    String?
  etapaEnvio            String    @default("AGUARDANDO_PAGAMENTO")
  criadoEm              DateTime  @default(now())
  atualizadoEm          DateTime  @updatedAt
}

model CotacaoFrete {
  id              String   @id @default(cuid())
  telefoneCliente String
  cepDestino      String
  cotacoes        Json
  expiradoEm      DateTime
  criadoEm        DateTime @default(now())
