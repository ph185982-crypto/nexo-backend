// ─── Oferta Gerada ─────────────────────────────────────────────────────────────

// ─── Financial Management ──────────────────────────────────────────────────────

model FinancialProfile {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  personType     String   // PESSOA_FISICA | PESSOA_JURIDICA
  cpfCnpj        String?
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  accounts       FinancialAccount[]
  transactions   FinancialTransaction[]
  recurringBills RecurringBill[]
  installmentPlans InstallmentPlan[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model FinancialAccount {
  id             String   @id @default(cuid())
  organizationId String
  profileId      String?
  name           String
  accountType    String   // CORRENTE | POUPANCA | CARTAO_CREDITO | DINHEIRO | INVESTIMENTO
  balance        Float    @default(0)
  creditLimit    Float?
  closingDay     Int?
  dueDay         Int?
  color          String?
  icon           String?
  isActive       Boolean  @default(true)
  profile        FinancialProfile? @relation(fields: [profileId], references: [id])
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  transactions   FinancialTransaction[]
  installmentPlans InstallmentPlan[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model FinancialCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String   // RECEITA | DESPESA
  icon           String?
  color          String?
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  transactions   FinancialTransaction[]
  recurringBills RecurringBill[]
  createdAt      DateTime @default(now())

  @@index([organizationId])
}

model FinancialTransaction {
  id                String   @id @default(cuid())
  organizationId    String
  profileId         String?
  accountId         String?
  categoryId        String?
  type              String   // RECEITA | DESPESA
  amount            Float
  description       String
  competencia       String?  // "2025-05" competency month for loans/cards
  status            String   @default("PENDENTE") // PENDENTE | PAGO | VENCIDO | CANCELADO
  dueDate           DateTime?
  paidAt            DateTime?
  proofMediaId      String?
  proofMediaUrl     String?
  recurringBillId   String?
  installmentPlanId String?
  installmentNumber Int?
  notes             String?  @db.Text
  profile           FinancialProfile? @relation(fields: [profileId], references: [id])
  account           FinancialAccount? @relation(fields: [accountId], references: [id])
  category          FinancialCategory? @relation(fields: [categoryId], references: [id])
  organization      WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  recurringBill     RecurringBill? @relation(fields: [recurringBillId], references: [id])
  installmentPlan   InstallmentPlan? @relation(fields: [installmentPlanId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, type])
}

model RecurringBill {
  id             String   @id @default(cuid())
  organizationId String
  profileId      String?
  categoryId     String?
  name           String
  amount         Float
  dueDay         Int      // day of month (1-31)
  isActive       Boolean  @default(true)
  startDate      DateTime
  endDate        DateTime?
  profile        FinancialProfile? @relation(fields: [profileId], references: [id])
  category       FinancialCategory? @relation(fields: [categoryId], references: [id])
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  transactions   FinancialTransaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model InstallmentPlan {
  id               String   @id @default(cuid())
  organizationId   String
  profileId        String?
  accountId        String?
  name             String
  totalAmount      Float
  installmentCount Int
  installmentValue Float
  competenciaStart String   // "2025-02" first competency month
  paidCount        Int      @default(0)
  isActive         Boolean  @default(true)
  profile          FinancialProfile? @relation(fields: [profileId], references: [id])
  account          FinancialAccount? @relation(fields: [accountId], references: [id])
  organization     WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  transactions     FinancialTransaction[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId])
}

model FinancialProofSession {
  id             String   @id @default(cuid())
  organizationId String
  phoneNumber    String
  mediaId        String
  mediaUrl       String?
  extractedText  String?  @db.Text
  extractedData  Json?
  status         String   @default("PENDING") // PENDING | IDENTIFIED | AWAITING_CONFIRM | AWAITING_CATEGORY | COMPLETED | REJECTED
  pendingData    Json?
  transactionId  String?
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId, phoneNumber])
  @@index([phoneNumber, status])
}

// ─── (end financial) ───────────────────────────────────────────────────────────

// ─── Checkout (link público de pagamento) ──────────────────────────────────────

model Checkout {
  id               String   @id @default(cuid())
  conversationId   String?
  telefoneCliente  String
  status           String   @default("PENDENTE")  // PENDENTE | PAGO | EXPIRADO
  nomeCliente      String?
  cep              String?
  enderecoCompleto String?
  numero           String?
  complemento      String?
  cidade           String?
  estado           String?
  produto          String?
  formaPagamento   String?
  pagamentoId      String?
  pagamentoTipo    String?  // legado — usar formaPagamento
  pixCopiaECola    String?  @db.Text
  pixQrCodeBase64  String?  @db.Text
  linkParcelado    String?
  valorProduto     Float    @default(197)
  criadoEm        DateTime @default(now())
  expiradoEm      DateTime
  atualizadoEm    DateTime @updatedAt

  @@index([conversationId])
  @@index([telefoneCliente])
}

// ─── ProspectSegment (Nexos Brasil — segmentos de prospecção) ──────────────────

model ProspectSegment {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  nome                  String
  termoBusca            String
  termosSecundarios     String[]
  cidades               String[]
  ativo                 Boolean  @default(true)
  pesoSemSite           Int      @default(3)
  pesoSemAnuncioAtivo   Int      @default(2)
  pesoInstagramParado   Int      @default(1)
  pesoRatingBaixo       Int      @default(1)
  limiarScoreQualificado Int     @default(4)
  apenasCelular         Boolean  @default(false)
  filtroSite            String   @default("TODOS") // TODOS | COM_SITE | SEM_SITE
  prospects             ProspectLead[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([organizationId, ativo])
}

// ─── ProspectLead (B2B Prospecção Nexos Brasil) ────────────────────────────────

model ProspectLead {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  leads                 Lead[]
  segmentId             String?
  segment               ProspectSegment? @relation(fields: [segmentId], references: [id])

  // Dados do negócio (vindos do sourcing)
  nome                  String?
  telefone              String?
  tipoTelefone          String?  // FIXO | CELULAR
  enderecoCompleto      String?
  website               String?
  placeId               String?  // Google Places ID — usado para dedupe

  // Dados de enriquecimento
  temSite               Boolean?
  temAnuncioAtivo       Boolean?
  instagramAtivo        Boolean?
  ultimaPostagemIG      DateTime?
  followersIG           Int?
  ratingGoogle          Float?
  numeroAvaliacoes      Int?

  // Scoring e análise
  score                 Int?
  analiseIA             String?  // PENDENTE | APROVAR_AUTO | REVISAR | DESCARTAR
  motivoAnaliseIA       String?

  // Status do pipeline
  // NOVO | ENRIQUECIDO | PONTUADO | ANALISADO | APROVADO | DESCARTADO
  // ABORDADO | RESPONDEU | QUALIFICADO | REUNIAO_AGENDADA | PERDIDO
  status                String   @default("NOVO")

  // Disparo
  templateUsadoId       String?
  templateUsado         TemplateProspeccao? @relation(fields: [templateUsadoId], references: [id])
  dataAbordagem         DateTime?
  tentativasDisparo     Int      @default(0)

  // Dados de prospecção ativa (preenchidos pela conversa)
  tipoNegocio           String?
  urgencia              String?
  sinalOportunidade     String?  @db.Text
  notas                 String?  @db.Text
  dataHoraReuniao       DateTime?
  googleCalendarEventId String?
  googleMeetLink        String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([placeId])
  @@index([organizationId, status])
  @@index([segmentId, status])
}

// ─── TemplateProspeccao ────────────────────────────────────────────────────────

model TemplateProspeccao {
  id               String   @id @default(cuid())
  organizationId   String
  organization     WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  nomeTemplateMeta String
  idioma           String   @default("pt_BR")
  variaveis        String[]
  ativo            Boolean  @default(true)
  prospects        ProspectLead[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([organizationId, ativo])
}

// ─── DisparoConfig ─────────────────────────────────────────────────────────────

model DisparoConfig {
  id                      String    @id @default(cuid())
  organizationId          String    @unique
  organization            WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  limiteDiarioAtual       Int       @default(15)
  incrementoSemanal       Int       @default(10)
  limiteMaximoDiario      Int       @default(100)
  janelaInicioHora        Int       @default(9)
  janelaFimHora           Int       @default(18)
  diasSemana              Int[]     @default([1, 2, 3, 4, 5])
  pausadoManualmente      Boolean   @default(false)
  motivoPausa             String?
  ultimaAtualizacaoLimite DateTime?
  diasEntreTentativas     Int       @default(3)
  maxTentativasContato    Int       @default(3)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// ─── IntegrationCredential (OAuth do usuário — ex.: Google Calendar) ──────────

model IntegrationCredential {
  id           String   @id @default(cuid())
  provider     String   @unique // "GOOGLE_CALENDAR"
  email        String?
  refreshToken String   @db.Text
  calendarId   String   @default("primary")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OfertaGerada {
  id                  String    @id @default(cuid())
  produtoId           String
  produto             Produto   @relation(fields: [produtoId], references: [id])
  nomeProduto         String
  precoCusto          Float
  precoVenda          Float
  precoDesconto       Float
  parcelamento        Float
  fotoOriginalUrl     String?
  artePath            String?
  textoOferta         String    @db.Text
  status              String    @default("PRONTA") // PRONTA | ENVIADA | FALHA
  enviadaParaWhatsApp Boolean   @default(false)
  enviadaEm           DateTime?
  criadaEm            DateTime  @default(now())

  @@index([produtoId, criadaEm])
}

// ─── Max — Assistente Pessoal Financeiro ─────────────────────────────────────

model Transacao {
  id              String   @id @default(uuid())
  tipo            String   // receita | despesa
  valor           Float
  descricao       String
  categoria       String
  tipo_negocio    String   @default("pessoal") // pessoal | vendedoria | lukaizen | geral
  empresa         String?
  data_transacao  DateTime @db.Date
  mes             String   // YYYY-MM
  confirmado      Boolean  @default(true)
  criado_em       DateTime @default(now())

  @@map("max_transacoes")
  @@index([data_transacao])
  @@index([categoria])
  @@index([mes])
}

model ConversaMax {
  id        String   @id @default(uuid())
  numero    String
  role      String   // user | assistant
  content   String   @db.Text
  criado_em DateTime @default(now())

  @@map("max_conversas")
  @@index([numero, criado_em])
}

model ContextoPedro {
  id             String   @id @default(uuid())
  chave          String   @unique
  valor          String   @db.Text
  categoria      String?  // financeiro | negocio | pessoal | meta | contato | rotina | outros
  atualizado_em  DateTime @default(now()) @updatedAt

  @@map("max_contexto_pedro")
}

model LembreteMax {
  id         String   @id @default(uuid())
  descricao  String
  data_hora  DateTime
  recorrente Boolean  @default(false)
  frequencia String?  // diario | semanal | mensal
  enviado    Boolean  @default(false)
  criado_em  DateTime @default(now())

  @@map("max_lembretes")
  @@index([enviado, data_hora])
}

model DividaMax {
  id              String   @id @default(uuid())
  descricao       String
  valor_total     Float
  valor_pago      Float    @default(0)
  parcela_mensal  Float?
  dia_vencimento  Int?
  credor          String?
  status          String   @default("ativa") // ativa | quitada
  observacao      String?
  criado_em       DateTime @default(now())

  @@map("max_dividas")
}

model MetaFinanceiraMax {
  id          String    @id @default(uuid())
  descricao   String
  valor_alvo  Float
  valor_atual Float     @default(0)
  tipo        String    @default("mensal")
  tipo_negocio String?
  data_inicio DateTime? @db.Date
  data_fim    DateTime? @db.Date
  status      String    @default("ativa")
  criado_em   DateTime  @default(now())

  @@map("max_metas_financeiras")
}

model ReceitaPrevistaMax {
  id               String    @id @default(uuid())
  descricao        String
  valor            Float
  data_prevista    DateTime  @db.Date
  tipo_negocio     String?
  cliente          String?
  status           String    @default("pendente") // pendente | atrasada | recebida
  data_recebimento DateTime?
  observacao       String?
  criado_em        DateTime  @default(now())

  @@map("max_receitas_previstas")
}

model TarefaMax {
  id                String    @id @default(uuid())
  descricao         String
  recorrente        Boolean   @default(false)
  frequencia        String?   // diario | semanal | mensal
  proxima_cobranca  DateTime?
  status            String    @default("ativa") // ativa | concluida | cancelada
  historico         Json      @default("[]")
  criado_em         DateTime  @default(now())

  @@map("max_tarefas")
}

model AlertaEnviadoMax {
  id         String   @id @default(uuid())
  chave      String   @unique
  enviado_em DateTime @default(now())

  @@map("max_alertas_enviados")
}

model ContaPagarMax {
  id              String    @id @default(uuid())
  descricao       String
  valor           Float
  data_vencimento DateTime  @db.Date
  categoria       String    @default("Outros")
  tipo_negocio    String    @default("pessoal")
  recorrente      Boolean   @default(false)
  frequencia      String?   // mensal | semanal | anual
  status          String    @default("pendente") // pendente | paga | cancelada
  transacao_id    String?
  criado_em       DateTime  @default(now())

  @@map("max_contas_pagar")
  @@index([status, data_vencimento])
}

model OrcamentoMax {
  id            String   @id @default(uuid())
  categoria     String   @unique
  limite_mensal Float
  criado_em     DateTime @default(now())

  @@map("max_orcamentos")
}

model WebhookEventMax {
  id          String   @id @default(uuid())
  from_number String?
  msg_type    String?
  msg_id      String?
  payload     Json?
  criado_em   DateTime @default(now())

  @@map("max_webhook_events")
  @@index([msg_id])
}
