generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("ADMIN") // ADMIN | MANAGER | SELLER
  accounts      Account[]
  sessions      Session[]
  pushSubscriptions PushSubscription[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Organization ──────────────────────────────────────────────────────────

model WhatsappBusinessOrganization {
  id           String   @id @default(cuid())
  name         String
  documentId   String
  documentType String   // CNPJ | CPF
  status       String   @default("ACTIVE") // ACTIVE | INACTIVE
  tipo         String   @default("VENDAS") // VENDAS | PROSPECCAO
  accounts     WhatsappProviderConfig[]
  leads        Lead[]
  campaigns    Campaign[]
  professionals ProfissionalEntity[]
  workUnits    WorkUnitEntity[]
  calendarEvents CalendarEvent[]
  hierarchyItems        OrgHierarchyItem[]
  products              Product[]
  ownerNotifications    OwnerNotification[]
  aiConfig              AiConfig?
  prospectLeads         ProspectLead[]
  prospectSegments      ProspectSegment[]
  templateProspeccao    TemplateProspeccao[]
  disparoConfig         DisparoConfig?
  financialProfiles     FinancialProfile[]
  financialAccounts     FinancialAccount[]
  financialCategories   FinancialCategory[]
  financialTransactions FinancialTransaction[]
  recurringBills        RecurringBill[]
  installmentPlans      InstallmentPlan[]
  financialProofSessions FinancialProofSession[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ─── WhatsApp ──────────────────────────────────────────────────────────────

model WhatsappProviderConfig {
  id                    String   @id @default(cuid())
  accountName           String
  displayPhoneNumber    String
  businessPhoneNumberId String
  wabaId                String?
  accessToken           String?
  status                String   @default("CONNECTED") // CONNECTED | DISCONNECTED | ERROR | BANNED
  organizationId        String
  organization          WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  agent                 Agent?
  conversations         WhatsappConversation[]
  campaigns             Campaign[]
  calendarEvents        CalendarEvent[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Agent {
  id                       String   @id @default(cuid())
  displayName              String
  kind                     String   // AI | HUMAN
  status                   String   @default("ACTIVE") // ACTIVE | INACTIVE
  sandboxMode              Boolean  @default(false)  // true = only send to approved test numbers
  whatsappProviderConfigId String   @unique
  config                   WhatsappProviderConfig @relation(fields: [whatsappProviderConfigId], references: [id])
  systemPrompt             String?  @db.Text
  aiProvider               String?  // OPENAI | ANTHROPIC
  aiModel                  String?  // gpt-4o | claude-3-5-sonnet
  escalationThreshold      Int      @default(3)
  orgHierarchyNode         OrgHierarchyItem?
  scriptVersions           AgentScriptVersion[]
  configVersions           AgentConfigVersion[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// ─── Agent Script Version History ─────────────────────────────────────────

model AgentScriptVersion {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  savedBy   String?  // user name or "configurador"
  createdAt DateTime @default(now())

  @@index([agentId, createdAt])
}

// ─── Agent Config Version History ─────────────────────────────────────────

model AgentConfigVersion {
  id                  String   @id @default(cuid())
  agentId             String
  agent               Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  systemPrompt        String?  @db.Text
  aiProvider          String?
  aiModel             String?
  nivelVenda          String   @default("medio")
  usarEmoji           Boolean  @default(true)
  usarReticencias     Boolean  @default(true)
  escalationThreshold Int      @default(3)
  tomDeVoz            String   @default("sincero")
  arquetipoIA         String?
  objetivoVenda       String   @default("fechar_venda")
  nivelUrgencia       Int      @default(3)
  matrizObjecoes      Json     @default("[]")
  restricoes          Json     @default("[]")
  followUpIntervalos        Json     @default("[4,24,48,72]")
  followUpMaxTentativas     Int      @default(4)
  savedBy             String?
  label               String?
  createdAt           DateTime @default(now())

  @@index([agentId, createdAt])
}

// ─── Legacy AgentConfig (singleton — global agent settings) ───────────────

model AgentConfig {
  id                   String              @id @default(cuid())
  agentName            String              @default("Pedro")
  bastaoNumber         String              @default("5562984465388")
  currentPrompt        String              @default("") @db.Text
  promptVersion        Int                 @default(1)
  followUpHours        String              @default("4,24,48,72")
  followUpPrompt       String?             @db.Text
  maxFollowUps         Int                 @default(4)
  deliveryWeekStart    Int                 @default(9)
  deliveryWeekEnd      Int                 @default(18)
  deliverySatStart     Int                 @default(8)
  deliverySatEnd       Int                 @default(13)
  deliveryArea         String              @default("")
  escalationThreshold  Int                 @default(3)
  aiProvider           String?
  aiModel              String?
  autoPassagem         Boolean             @default(true)
  autoMedia            Boolean             @default(true)
  escalacaoAtiva       Boolean             @default(true)
  personalityProfileId String?
  personalityProfile   PersonalityProfile? @relation(fields: [personalityProfileId], references: [id])
  strategyProfileId    String?
  strategyProfile      StrategyProfile?    @relation(fields: [strategyProfileId], references: [id])
  promptHistory        AgentPromptHistory[]
  updatedAt            DateTime            @updatedAt
  createdAt            DateTime            @default(now())
}

model AgentPromptHistory {
  id            String      @id @default(cuid())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
  content       String      @db.Text
  version       Int         @default(1)
  savedBy       String?
  createdAt     DateTime    @default(now())

  @@index([agentConfigId, createdAt])
}

// ─── Kanban ────────────────────────────────────────────────────────────────

model KanbanColumn {
  id              String   @id @default(cuid())
  name            String
  order           Int
  type            String   // CUSTOM | ESCALATED | LOST | TRIAGE | JUNK
  isSystemDefault Boolean  @default(false)
  isDefaultEntry  Boolean  @default(false)
  organizationId  String
  color           String   // hex color
  leads           Lead[]
  createdAt       DateTime @default(now())
}

// ─── Leads ─────────────────────────────────────────────────────────────────

model Lead {
  id             String   @id @default(cuid())
  phoneNumber    String
  profileName    String?
  email          String?
  cpf            String?
  location       String?
  leadOrigin     String   // OUTBOUND | INBOUND
  status         String   @default("OPEN") // OPEN | ESCALATED | CLOSED | BLOCKED
  organizationId String
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  kanbanColumnId String
  kanbanColumn   KanbanColumn @relation(fields: [kanbanColumnId], references: [id])
  conversations  WhatsappConversation[]
  activities     LeadActivity[]
  escalations    LeadEscalation[]
  tags           LeadTag[]
  calendarEvents CalendarEvent[]
  notes          LeadNote[]
  prospectLead   ProspectLead? @relation(fields: [prospectLeadId], references: [id])
  prospectLeadId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastActivityAt DateTime?
}

model LeadActivity {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  type        String   // NOTE | CALL | EMAIL | MEETING | STATUS_CHANGE | TAG_ADDED
  description String   @db.Text
  createdBy   String?
  createdAt   DateTime @default(now())
}

model LeadEscalation {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  reason      String?  @db.Text
  escalatedTo String?
  status      String   @default("PENDING") // PENDING | ACCEPTED | RESOLVED
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
}

model Tag {
  id            String   @id @default(cuid())
  name          String
  color         String
  kind          String   // SPECULATIVE | HOT | COLD | QUALIFIED | LOST | CUSTOM
  organizationId String?
  leadTags      LeadTag[]
  conversationTags ConversationTag[]
  createdAt     DateTime @default(now())
}

model LeadTag {
  leadId String
  tagId  String
  lead   Lead   @relation(fields: [leadId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([leadId, tagId])
}

// ─── Conversations ─────────────────────────────────────────────────────────

model WhatsappConversation {
  id                         String   @id @default(cuid())
  customerWhatsappBusinessId String
  profileName                String?
  leadOrigin                 String   // OUTBOUND | INBOUND
  leadId                     String
  lead                       Lead     @relation(fields: [leadId], references: [id])
  whatsappProviderConfigId   String
  provider                   WhatsappProviderConfig @relation(fields: [whatsappProviderConfigId], references: [id])
  messages                   WhatsappMessage[]
  tags                       ConversationTag[]
  followUp                   ConversationFollowUp?
  decisionLogs               DecisionLog[]
  conversationRatings        Json     @default("[]")
  lastMessageAt              DateTime?
  isActive                   Boolean  @default(true)
  humanTakeover              Boolean  @default(false) // true = IA pausada, humano está no controle

  // ── EstadoConversa: estado rastreado por código (não pela IA) ─────────────
  etapa              String   @default("NOVO")      // NOVO | PRODUTO_IDENTIFICADO | MIDIA_ENVIADA | QUALIFICANDO | NEGOCIANDO | COLETANDO_DADOS | PEDIDO_CONFIRMADO | PERDIDO
  produtoInteresse   String?                         // BOMVINK_21V | LUATEK_48V
  midiaEnviada       Boolean  @default(false)
  localizacaoRecebida Boolean @default(false)
  foraAreaEntrega    Boolean  @default(false)
  resumoEnviado      Boolean  @default(false)
  cortesiasAposConf  Int      @default(0)            // contador de mensagens de cortesia pós-confirmação
  localizacaoTexto   String?  @db.Text
  nomeRecebedor      String?
  horarioEntrega     String?
  formaPagamento     String?
  sessaoNacional     Json?                           // dados do fluxo de venda nacional
  sessaoProspeccao   Json?                           // dados do fluxo de prospecção B2B
  midiasEnviadas     Json?    @default("[]")          // slugs de mídia já enviados nesta conversa

  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ConversationFollowUp {
  id               String               @id @default(cuid())
  conversationId   String               @unique
  conversation     WhatsappConversation @relation(fields: [conversationId], references: [id])
  step             Int                  @default(1)    // 1=4h 2=24h 3=48h 4=72h 5=done
  status           String               @default("ACTIVE") // ACTIVE | DONE | OPT_OUT
  leadName         String?
  phoneNumber      String               // recipient to send follow-up to
  phoneNumberId    String               // Meta phone number ID for sending
  accessToken      String?              // WhatsApp access token
  aiMessageAt      DateTime             // reference: when AI last messaged
  nextSendAt       DateTime             // aiMessageAt + interval for current step
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model ConversationTag {
  conversationId String
  tagId          String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id])
  tag            Tag                  @relation(fields: [tagId], references: [id])

  @@id([conversationId, tagId])
}

model WhatsappMessage {
  id             String   @id @default(cuid())
  content        String   @db.Text
  type           String   // TEXT | IMAGE | AUDIO | VIDEO | DOCUMENT
  role           String   // ASSISTANT | USER
  sentAt         DateTime
  mediaUrl       String?
  caption        String?
  repliedToId    String?
  status         String   @default("SENT") // SENT | DELIVERED | READ | FAILED
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id])
}

// ─── Campaigns ─────────────────────────────────────────────────────────────

model Campaign {
  id                       String   @id @default(cuid())
  name                     String
  objective                String   // OUTBOUND | CALENDAR | FOLLOW_UP
  status                   String   @default("PLANNING") // PLANNING | ACTIVE | PAUSED | COMPLETED | CANCELLED
  mode                     String   @default("DEFAULT") // DEFAULT | PARALLEL
  triggerType              String   @default("SCHEDULED") // SCHEDULED | IMMEDIATE
  scheduledAt              DateTime?
  templateMessage          String   @db.Text
  templateName             String?
  phoneColumn              String?
  identificationColumn     String?
  variableMapping          Json?
  minDelaySeconds          Int      @default(15)
  maxDelaySeconds          Int      @default(45)
  maxMessagesPerMinute     Int      @default(5)
  dailyStartTime           String   @default("08:00")
  dailyEndTime             String   @default("20:00")
  maxConsecutiveDays       Int      @default(7)
  skipExistingConversation Boolean  @default(true)
  useAiOptimization        Boolean  @default(false)
  organizationId           String
  organization             WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  senderId                 String
  sender                   WhatsappProviderConfig @relation(fields: [senderId], references: [id])
  recipients               CampaignRecipient[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model CampaignRecipient {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  phoneNumber String
  name        String?
  status      String   @default("PENDING") // PENDING | SENT | FAILED | REPLIED | SKIPPED
  sentAt      DateTime?
  metadata    Json?
}

// ─── Calendar ──────────────────────────────────────────────────────────────

model CalendarEvent {
  id                       String   @id @default(cuid())
  title                    String
  description              String?  @db.Text
  location                 String?
  startTime                DateTime
  endTime                  DateTime
  timezone                 String   @default("America/Sao_Paulo")
  isAllDay                 Boolean  @default(false)
  status                   String   @default("SCHEDULED") // SCHEDULED | COMPLETED | CANCELLED
  provider                 String   @default("LOCAL") // LOCAL | GOOGLE
  externalEventId          String?
  googleMeetLink           String?
  organizationId           String
  organization             WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  workUnitId               String?
  workUnit                 WorkUnitEntity? @relation(fields: [workUnitId], references: [id])
  profissionalId           String?
  profissional             ProfissionalEntity? @relation(fields: [profissionalId], references: [id])
  whatsappProviderConfigId String?
  provider_config          WhatsappProviderConfig? @relation(fields: [whatsappProviderConfigId], references: [id])
  leadId                   String?
  lead                     Lead?    @relation(fields: [leadId], references: [id])
  attendees                CalendarAttendee[]
  reminders                CalendarReminder[]
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model CalendarAttendee {
  id              String        @id @default(cuid())
  calendarEventId String
  event           CalendarEvent @relation(fields: [calendarEventId], references: [id])
  name            String
  email           String?
  phone           String?
  status          String        @default("INVITED") // INVITED | CONFIRMED | DECLINED
}

model CalendarReminder {
  id              String        @id @default(cuid())
  calendarEventId String
  event           CalendarEvent @relation(fields: [calendarEventId], references: [id])
  minutesBefore   Int
  channel         String        // WHATSAPP | EMAIL | PUSH
  sent            Boolean       @default(false)
}

// ─── Professionals & Work Units ────────────────────────────────────────────

model ProfissionalEntity {
  id                String   @id @default(cuid())
  name              String
  description       String?  @db.Text
  workField         String?
  imageUrl          String?
  isActive          Boolean  @default(true)
  loginEmail        String?
  isCalendarOffline Boolean  @default(false)
  organizationId    String
  organization      WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  workProfiles      ProfissionalWorkProfile[]
  availabilities    ProfissionalAvailability[]
  calendarEvents    CalendarEvent[]
}

model ProfissionalAvailability {
  id             String             @id @default(cuid())
  profissionalId String
  profissional   ProfissionalEntity @relation(fields: [profissionalId], references: [id])
  dayOfWeek      Int                // 0-6 (Dom-Sáb)
  startTime      String             // "08:00"
  endTime        String             // "18:00"
  breakMinutes   Int                @default(0)
  isActive       Boolean            @default(true)
}

model WorkUnitEntity {
  id             String   @id @default(cuid())
  name           String
  address        String?
  timezone       String   @default("America/Sao_Paulo")
  isActive       Boolean  @default(true)
  organizationId String
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  professionals  ProfissionalWorkProfile[]
  calendarEvents CalendarEvent[]
}

model ProfissionalWorkProfile {
  id             String             @id @default(cuid())
  profissionalId String
  profissional   ProfissionalEntity @relation(fields: [profissionalId], references: [id])
  workUnitId     String
  workUnit       WorkUnitEntity     @relation(fields: [workUnitId], references: [id])
  role           String?
  isActive       Boolean            @default(true)

  @@unique([profissionalId, workUnitId])
}

// ─── Org Hierarchy ─────────────────────────────────────────────────────────

model OrgHierarchyItem {
  id             String           @id @default(cuid())
  parentId       String?
  parent         OrgHierarchyItem?  @relation("hierarchy", fields: [parentId], references: [id])
  children       OrgHierarchyItem[] @relation("hierarchy")
  type           String           // FOLDER | AGENT_NODE
  name           String
  description    String?
  agentId        String?          @unique
  agent          Agent?           @relation(fields: [agentId], references: [id])
  organizationId String
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  order          Int              @default(0)
  createdAt      DateTime         @default(now())
}

// ─── Owner Notifications ───────────────────────────────────────────────────

model OwnerNotification {
  id             String   @id @default(cuid())
  type           String   // ORDER | ESCALATION | OPT_OUT
  title          String
  body           String   @db.Text
  read           Boolean  @default(false)
  organizationId String
  organization   WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  leadId         String?
  conversationId String?
  createdAt      DateTime @default(now())
}

// ─── Product Catalog ───────────────────────────────────────────────────────

model Product {
  id                String   @id @default(cuid())
  name              String
  description       String?  @db.Text
  especificacoes    String?  @db.Text  // specs técnicas injetadas no contexto da IA
  price             Float
  priceInstallments Float?
  installments      Int      @default(10)
  imageUrl          String?           // legacy / primary image
  imageUrls         String[]          // up to 8 images
  videoUrl          String?
  category          String?
  isActive          Boolean  @default(true)
  organizationId    String
  organization      WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── AI Config ─────────────────────────────────────────────────────────────

model AiConfig {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  organization    WhatsappBusinessOrganization @relation(fields: [organizationId], references: [id])
  usarEmoji       Boolean  @default(true)
  usarReticencias Boolean  @default(true)
  nivelVenda      String   @default("medio")         // leve | medio | agressivo
  tomDeVoz        String   @default("sincero")        // sincero | agressivo | consultivo
  arquetipoIA     String?
  objetivoVenda   String   @default("fechar_venda")   // fechar_venda | gerar_lead | qualificar
  nivelUrgencia   Int      @default(3)                // 1-5
  matrizObjecoes  Json     @default("[]")
  restricoes      Json     @default("[]")
  followUpIntervalos    Json     @default("[4,24,48,72]") // hours[]
  followUpMaxTentativas Int      @default(4)
  updatedAt       DateTime @updatedAt
}

// ─── Decision Log ─────────────────────────────────────────────────────────

model DecisionLog {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id])
  action         String               // RESPOND | FOLLOW_UP | ESCALATE | WAIT | CLOSE
  reason         String?              @db.Text
  metadata       Json?
  createdAt      DateTime             @default(now())

  @@index([conversationId, createdAt])
}

// ─── Webhook Retry Queue ────────────────────────────────────────────────────

model WebhookQueue {
  id          String   @id @default(cuid())
  payload     String   @db.Text   // raw JSON body from Meta
  signature   String              // x-hub-signature-256 header
  attempts    Int      @default(0)
  status      String   @default("PENDING") // PENDING | PROCESSED | FAILED
  error       String?  @db.Text
  createdAt   DateTime @default(now())
  retryAfter  DateTime @default(now())
}


// ─── Lead Notes ────────────────────────────────────────────────────────────────

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdBy String?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
}

// ─── Push Subscriptions ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Personality Profiles (AI Command Center) ─────────────────────────────────

model PersonalityProfile {
  id          String        @id @default(cuid())
  name        String
  tone        String        @db.Text
  archetype   String
  emoji       String        @default("👤")
  isActive    Boolean       @default(true)
  agentConfig AgentConfig[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ─── Strategy Profiles (AI Command Center) ────────────────────────────────────

model StrategyProfile {
  id          String        @id @default(cuid())
  name        String
  description String        @db.Text
  salesGoal   String
  urgency     String        @default("medium") // low | medium | high
  isActive    Boolean       @default(true)
  agentConfig AgentConfig[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

// ─── Objection Rules (AI Command Center) ──────────────────────────────────────

model ObjectionRule {
  id               String   @id @default(cuid())
  keyword          String
  objectionType    String   // PRICE | COMPETITOR | TIMING | DISINTEREST | TRUST | FEATURE
  responseStrategy String   @db.Text
  counterArgument  String   @db.Text
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─── Constraint Rules (AI Command Center) ─────────────────────────────────────

model ConstraintRule {
  id        String   @id @default(cuid())
  title     String
  rule      String   @db.Text
  reason    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Produto (Portuguese catalog — legacy feed importer) ──────────────────────

model Produto {
  id                 String        @id @default(cuid())
  nome               String
  slug               String        @unique
  precoCusto         Float         @default(0)
  precoVenda         Float
  precoDesconto      Float
  parcelamento       Float         @default(0)
  fotoUrl            String?
  descricao          String?       @db.Text
  categoria          String?
  ativo              Boolean       @default(true)
  ehFerramenta       Boolean       @default(true)
  importadoEm        DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt
  ultimaOfertaEm     DateTime?
  vezesUsadoEmOferta Int           @default(0)
  ofertas            OfertaGerada[]
}

