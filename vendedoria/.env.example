# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vendedoria"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# WhatsApp Business API (Meta)
META_WHATSAPP_VERIFY_TOKEN="your-verify-token"
META_WHATSAPP_ACCESS_TOKEN="your-access-token"
META_WHATSAPP_APP_SECRET="your-app-secret"

# Google OAuth (Calendar + Meet)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# AI (OpenAI or Anthropic)
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Campaign Worker (Vercel Cron protection)
CRON_SECRET="gere-um-secret-seguro-aqui"
