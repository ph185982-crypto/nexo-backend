# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vendedoria"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# WhatsApp Business API (Meta)
META_WHATSAPP_VERIFY_TOKEN="your-verify-token"
META_WHATSAPP_ACCESS_TOKEN="your-access-token"
META_WHATSAPP_APP_SECRET="your-app-secret"

# Google OAuth (Calendar + Meet)
GOOGLE_CALENDAR_CLIENT_ID="your-google-calendar-client-id"
GOOGLE_CALENDAR_CLIENT_SECRET="your-google-calendar-client-secret"

# Sourcing de empresas (prospecção B2B) — RapidAPI é a fonte primária;
# Google Places é fallback opcional. Configure pelo menos uma.
RAPIDAPI_KEY="sua-chave-rapidapi"   # local-business-data (+ Instagram no enriquecimento)
GOOGLE_PLACES_API_KEY="AIzaSy..."

# AI (escolha um ou mais — auto-detect prioriza Anthropic → Google → OpenAI)
OPENAI_API_KEY="sk-..."          # GPT-4o + Whisper (transcrição de áudio)
ANTHROPIC_API_KEY="sk-ant-..."   # Claude Sonnet
GOOGLE_AI_API_KEY="AIzaSy..."    # Gemini 2.0 Flash

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Campaign Worker (Vercel Cron protection)
CRON_SECRET="gere-um-secret-seguro-aqui"
